# Webex Device Assistant user service environment example
# Copy this file to webex-device-assistant.env and fill real values locally.

ADMIN_STATE_PATH="/home/p1481/youngcle_code/06. Device Assistant/.deploy/admin-state.json"
DEFAULT_EXECUTION_MODE=separated
DEFAULT_TARGET_DEVICE=
DEFAULT_PROVIDER=rule_based
DEFAULT_PROVIDER_MODEL=rule-based-default
# DEFAULT_PROVIDER_BASE_URL=http://127.0.0.1:11434/api

# Safe local defaults.
WEBEX_MOCK_MODE=true
DEVICE_MOCK_MODE=true
WEBEX_WEBHOOK_RECONCILE_ON_STARTUP=false

# Required when WEBEX_MOCK_MODE=false.
WEBEX_BOT_TOKEN=
WEBEX_BOT_PERSON_ID=
WEBEX_WEBHOOK_SECRET=
WEBEX_WEBHOOK_TARGET_URL=https://example.com/webhooks/webex/messages

# Required when DEVICE_MOCK_MODE=false.
WEBEX_TOKEN_MANAGER_BASE_URL=http://127.0.0.1:3000
WEBEX_TOKEN_MANAGER_API_KEY=
